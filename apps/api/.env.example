# API читает переменные из .env в корне репозитория (см. apps/api/src/env.js).
# Для изоляции можно переопределить ключи в apps/api/.env

PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=assistant
DB_USER=postgres
DB_PASSWORD=example

JWT_SECRET=change_me_in_production_use_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_use_different_long_random_string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

STORAGE_TYPE=local
S3_ENDPOINT=http://localhost:9000
S3_USER=minioadmin
S3_PASSWORD=minioadmin
S3_BUCKET=assistant
S3_REGION=us-east-1

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!

CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3001

# Пути RAG/Chroma относительно монорепозитория (по умолчанию вычисляются в python.js)
# BACKEND_ROOT=../../backend
# INGEST_SCRIPT_PATH=
# KB_PATH=
# CHROMA_DB_PATH=
