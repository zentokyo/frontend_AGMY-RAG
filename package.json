{
  "name": "agmy-rag-admin",
  "version": "1.0.0",
  "description": "Admin panel for AGMY RAG system — Knowledge Base & Q&A management",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server run start",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install",
    "db:migrate": "npm --prefix server run db:migrate",
    "db:seed": "npm --prefix server run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
