{
  "name": "agmy-rag-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:chat\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:admin": "npm --prefix apps/admin-frontend run dev",
    "dev:chat": "npm --prefix apps/chat-frontend run dev",
    "build": "npm --prefix apps/admin-frontend run build",
    "build:chat": "npm --prefix apps/chat-frontend run build",
    "start": "npm --prefix apps/api run start",
    "install:all": "npm install && npm --prefix apps/api install && npm --prefix apps/admin-frontend install && npm --prefix apps/chat-frontend install",
    "db:migrate": "npm --prefix apps/api run db:migrate",
    "db:seed": "npm --prefix apps/api run db:seed",
    "test:api": "npm --prefix apps/api test",
    "test:e2e": "npm --prefix apps/chat-frontend run e2e",
    "test:all": "npm run test:api && npm run build && npm run build:chat",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:dev": "docker compose --profile dev up -d --build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
