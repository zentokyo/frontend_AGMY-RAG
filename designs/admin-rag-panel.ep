      <text x="2000" y="326" font-size="30" font-weight="700" fill="#0F172A">148</text>
      <rect x="2220" y="260" width="220" height="120" rx="12" fill="#FFFFFF" stroke="#E2E8F0"/>
      <text x="2240" y="286" font-size="13" fill="#64748B">Вопросов Q&amp;A</text>
      <text x="2240" y="326" font-size="30" font-weight="700" fill="#0F172A">312</text>
