  <p:Content>
    <svg xmlns="http://www.w3.org/2000/svg" width="5600" height="900" viewBox="0 0 5600 900">
      <!-- Login -->
      <rect x="80" y="80" width="1280" height="720" fill="#F1F5F9"/>
