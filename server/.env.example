PORT=3001
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agmy_admin
DB_USER=postgres
DB_PASSWORD=changeme

# JWT
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_use_different_long_random_string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Paths to the Python ai_support project (relative to server/)
KB_PATH=../../ai_support/knowledge_base
CHROMA_DB_PATH=../../ai_support/db_metadata_v5
PYTHON_PATH=python3
INGEST_SCRIPT_PATH=../../ai_support/ingest.py
ADMIN_TOOLS_PATH=../python/admin_tools.py

# Seed admin account (used on first db:seed run)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!

# CORS — React dev server origin
CLIENT_ORIGIN=http://localhost:5173
