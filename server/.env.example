PORT=3001
NODE_ENV=development

# PostgreSQL — AGMY_RAG shared database (same as assistant_db)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assistant
DB_USER=postgres
DB_PASSWORD=example

# JWT secrets for admin panel
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_use_different_long_random_string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# MinIO / S3 file storage (same as AGMY_RAG)
S3_ENDPOINT=http://localhost:7000
S3_USER=minioadmin
S3_PASSWORD=minioadmin
S3_BUCKET=assistant
S3_REGION=us-east-1

# Seed admin account (used on first db:seed run)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!

# CORS — React dev server origin
CLIENT_ORIGIN=http://localhost:5173
