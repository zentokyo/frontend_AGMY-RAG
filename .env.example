# =============================================================================
# AGMY RAG — единый .env для Docker Compose (корень репозитория)
# Скопируйте: cp .env.example .env
# =============================================================================

# --- PostgreSQL (FastAPI, бот, Alembic; префикс POSTGRES_ для backend) ---
POSTGRES_HOST=assistant_db
POSTGRES_PORT=5432
POSTGRES_PUBLISHED_PORT=5433
POSTGRES_DB=assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=example

# --- Qdrant (векторная БД) ---
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=assistant_knowledge
QDRANT_VECTOR_SIZE=2560
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MIN_CHUNK_CHARS=40
RAG_RETRIEVAL_FETCH_K=30
RAG_HYBRID_RERANK_ENABLED=true
RAG_HYBRID_VECTOR_WEIGHT=0.78
RAG_HYBRID_LEXICAL_WEIGHT=0.22
RAG_MMR_ENABLED=true
RAG_MMR_LAMBDA=0.82
RAG_MAX_CONTEXT_CHARS=8000
RAG_OCR_ENABLED=true
RAG_OCR_LANGUAGE=rus+eng
RAG_OCR_MIN_CHARS_PER_PAGE=40
RAG_OCR_CONCURRENCY=1
RAG_ADMIN_REINDEX_CONCURRENCY=2
RAG_UPLOAD_STORAGE_CONCURRENCY=4
RAG_UPLOAD_INDEX_CONCURRENCY=2
RAG_INGEST_WORKER_BATCH_SIZE=2
RAG_INGEST_WORKER_POLL_SECONDS=3
RAG_INGEST_STALE_AFTER_SECONDS=1800
RAG_INGEST_MAX_ATTEMPTS=3
KB_PATH=backend/src/core/rag/knowledge_base

# --- DeepSeek V4 Flash (LLM для оценки ответов и AI-ментора) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096

# --- GigaChat (эмбеддинги RAG, backend) ---
GIGACHAT_AUTHORIZATION_KEY=your_gigachat_token
GIGACHAT_EMBEDDINGS_MODEL=EmbeddingsGigaR
GIGACHAT_EMBEDDINGS_BATCH_SIZE=8
GIGACHAT_EMBEDDINGS_CONCURRENCY=1
GIGACHAT_EMBEDDINGS_MAX_RETRIES=5
GIGACHAT_EMBEDDINGS_RETRY_BASE_SECONDS=1.5
# Для EmbeddingsGigaR Сбер рекомендует добавлять инструкцию к retrieval-запросам.
GIGACHAT_EMBEDDINGS_QUERY_INSTRUCTION=Дан вопрос, необходимо найти абзац текста с ответом\nвопрос: {query}

# --- Telegram-бот ---
BOT_TOKEN=your_telegram_bot_token
EXAM_API_BASE_URL=http://assistant_backend:8000

# --- FastAPI ---
FASTAPI_PUBLISHED_PORT=8001
INTERNAL_API_TOKEN=change-me-internal-token

# --- MinIO / S3 (префикс S3_ как в backend) ---
S3_HOST=assistant-file-storage
S3_PORT=9000
S3_USER=minioadmin
S3_PASSWORD=minioadmin
S3_BUCKET=assistant

# --- Web auth (FastAPI) ---
JWT_SECRET=change_me_access_use_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_different_long_random_string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
COOKIE_SECURE=false

# Несколько origin через запятую для dev-серверов Vite
CLIENT_ORIGIN=http://127.0.0.1:5173,http://127.0.0.1:5174

# --- Vite фронты при прямом подключении к FastAPI ---
VITE_API_BASE=http://127.0.0.1:8001/api

# Первый админ (`npm run db:seed`)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
